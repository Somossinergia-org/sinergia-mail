{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/sync",
      "schedule": "0 7 * * 1-5"
    },
    {
      "path": "/api/cron/weekly-report",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/process-outbound",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/process-sequences",
      "schedule": "*/15 * * * *"
    }
  ],
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install"
}
