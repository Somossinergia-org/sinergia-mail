# ═══════════════════════════════════════════════════════════════════════════════
# SINERGIA — Entorno STAGING (Pre-producción)
# ═══════════════════════════════════════════════════════════════════════════════
# Copiar a .env.local para desarrollo local o configurar en Vercel Staging env.
# Modo: shadow — procesa todo pero NO envía comunicaciones reales.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Modo de operación ─────────────────────────────────────────────────────────
# dry-run   = sin LLM, sin comms (solo para tests)
# shadow    = LLM activo, comms simuladas (staging recomendado)
# guarded   = LLM activo, comms reales con aprobación humana
# production = autónomo completo
SINERGIA_MODE=shadow

# ── Seguridad: Encriptación de tokens OAuth ──────────────────────────────────
# Generar con: openssl rand -base64 32
# OBLIGATORIO en staging y producción
TOKEN_ENCRYPTION_KEY=GENERAR-CON-openssl-rand-base64-32

# ── Kill Switches (staging: todo bloqueado excepto lo que probamos) ───────────
KILL_BLOCK_ALL_COMMS=true
KILL_BLOCK_WA_SMS_PHONE=true
KILL_BLOCK_DELEGATION=false
KILL_BLOCK_HIGH_RISK=false
KILL_FORCE_READONLY=false
KILL_DISABLE_JUNIOR=false
KILL_BLOCKED_CHANNELS=whatsapp,sms,phone

# ── Rate Limits (staging: restrictivos para detectar problemas rápido) ────────
LIMIT_MSG_PER_CASE=5
LIMIT_MSG_PER_CLIENT=10
LIMIT_CLIENT_WINDOW_MIN=60
LIMIT_CALLS_PER_CASE=1
LIMIT_ESCALATIONS=2
LIMIT_TOOL_RETRIES=2
LIMIT_CONTACT_COOLDOWN=300
LIMIT_HIGH_RISK_PER_CASE=2

# ── Observabilidad ────────────────────────────────────────────────────────────
LOG_LEVEL=debug
# SENTRY_DSN= (configurar si disponible)

# ── Nota ──────────────────────────────────────────────────────────────────────
# Las demás variables (DATABASE_URL, GOOGLE_*, OPENAI_API_KEY, etc.)
# deben configurarse en Vercel Dashboard > Settings > Environment Variables
# para el entorno Preview/Development, o en .env.local para desarrollo.
