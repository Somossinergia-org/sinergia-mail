# ════════════════════════════════════════════════════════════════
# Sinergia Mail — Environment variables
# ════════════════════════════════════════════════════════════════
# Copia este archivo a `.env.local` y rellena los valores reales.
# NUNCA commitees `.env.local` — ya está en `.gitignore`.

# ─── Google OAuth ────────────────────────────────────────────────
# console.cloud.google.com > APIs & Services > Credentials
# Scopes requeridos: openid, email, profile, gmail.readonly,
# gmail.compose, gmail.modify
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret

# ─── NextAuth ────────────────────────────────────────────────────
# Genera NEXTAUTH_SECRET con: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=genera-con-openssl-rand-base64-32

# ─── Cloud SQL PostgreSQL ────────────────────────────────────────
# Formato: postgresql://usuario:password@host:puerto/database
# En producción usamos Cloud SQL con SSL (rejectUnauthorized: false)
DATABASE_URL=postgresql://postgres:password@host:5432/sinergia_mail

# ─── Google Gemini API ───────────────────────────────────────────
# aistudio.google.com/app/apikey
# Modelo utilizado: gemini-2.5-flash
GEMINI_API_KEY=AIza...

# ─── Vercel Cron (opcional) ──────────────────────────────────────
# Genera con: openssl rand -base64 32
# Protege endpoints /api/cron/* de llamadas externas
CRON_SECRET=genera-con-openssl-rand-base64-32

# ─── Observabilidad (opcional) ───────────────────────────────────
# Si se define, el logger envía errores a Sentry.
# Si está vacío, solo loguea a stdout.
SENTRY_DSN=

# Nivel de log: debug | info | warn | error | fatal
# Default: info en production, debug en development
LOG_LEVEL=info
