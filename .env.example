# Google OAuth (console.cloud.google.com > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=genera-uno-con-openssl-rand-base64-32

# Vercel Postgres (se autoconfigura en Vercel, solo para local)
POSTGRES_URL=postgres://...
POSTGRES_PRISMA_URL=postgres://...
POSTGRES_URL_NON_POOLING=postgres://...

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Vercel Cron Secret (para sync automático)
CRON_SECRET=genera-uno-con-openssl-rand-base64-32
