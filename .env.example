# ============================================================================
# SINERGIA MAIL — Environment Variables (Completo)
# ============================================================================
# Copia este archivo a .env.local y rellena los valores.
# NUNCA commitees .env.local — ya esta en .gitignore.
# Tambien configurar en: Vercel Dashboard > Settings > Environment Variables.
#
# Verificar estado: GET /api/admin/api-status
# ============================================================================

# ── Core: Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/sinergia?sslmode=require

# ── Core: Authentication ────────────────────────────────────────────────────
# Genera NEXTAUTH_SECRET con: openssl rand -base64 32
NEXTAUTH_URL=https://your-domain.vercel.app
NEXTAUTH_SECRET=genera-con-openssl-rand-base64-32

# ── Core: Google OAuth (Gmail, Calendar, Drive, Tasks) ──────────────────────
# console.cloud.google.com > APIs & Services > Credentials
# Scopes: openid, email, profile, gmail.readonly, gmail.compose, gmail.modify,
#          calendar, drive, tasks
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# ── Core: OpenAI (Motor IA principal del swarm) ───────────────────────────
# Modelo: gpt-4o por defecto. Cambiar a gpt-5 cuando este disponible.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxx
GPT5_MODEL=gpt-4o
GPT5_MAX_TOKENS=4096
GPT5_TEMPERATURE=0.7

# ── Core: Gemini (IA de respaldo) ──────────────────────────────────────────
# aistudio.google.com/app/apikey — Modelo: gemini-2.5-flash
GEMINI_API_KEY=AIza-xxxx

# ── Channel: Twilio (SMS + Llamadas telefonicas) ─────────────────────────
# Free trial: $15 credito. Luego ~$1.15/mes/numero + $0.0079/SMS
# https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_PHONE_DEFAULT=+34600000000
# Opcional: numeros dedicados por agente
# TWILIO_PHONE_CEO=+34600000001
# TWILIO_PHONE_CRM_DIRECTOR=+34600000002

# ── Channel: WhatsApp Business Cloud API ──────────────────────────────────
# Meta Business Suite > WhatsApp > API Setup
# Free: 1000 conversaciones/mes
# https://business.facebook.com
WHATSAPP_PHONE_NUMBER_ID=123456789
WHATSAPP_ACCESS_TOKEN=EAAxxxx
WHATSAPP_VERIFY_TOKEN=sinergia-whatsapp-2026

# ── Channel: Telegram Bot ────────────────────────────────────────────────
# 100% gratis, ilimitado. Crear bot en @BotFather
TELEGRAM_BOT_TOKEN=123456:ABCxxxx

# ── Channel: Resend (Email transaccional) ─────────────────────────────────
# Free: 3,000 emails/mes. https://resend.com
RESEND_API_KEY=re_xxxx

# ── AI: ElevenLabs (Voces IA para agentes) ────────────────────────────────
# Free: 10,000 chars/mes. Cada agente tiene voz unica.
# https://elevenlabs.io
ELEVENLABS_API_KEY=sk_xxxx

# ── AI: Deepgram (Speech-to-Text) ───────────────────────────────────────
# Free: $200 creditos. Modelo Nova-2 para espanol.
# https://deepgram.com
DEEPGRAM_API_KEY=xxxx

# ── AI: Stability AI (Generacion de imagenes) ───────────────────────────
# Free para empresas <$1M revenue. ~$0.04/imagen despues.
# https://platform.stability.ai
STABILITY_API_KEY=sk-xxxx

# ── AI: Google Cloud Vision (OCR) ───────────────────────────────────────
# Free: 1,000 unidades/mes. Para facturas y documentos escaneados.
# https://cloud.google.com/vision
GOOGLE_CLOUD_VISION_KEY=AIza-xxxx

# ── Search: Google Custom Search ─────────────────────────────────────────
# Free: 100 consultas/dia. Fallback a DuckDuckGo si no configurado.
# https://programmablesearchengine.google.com
GOOGLE_SEARCH_API_KEY=AIza-xxxx
GOOGLE_SEARCH_CX=xxxx

# ── Observabilidad (opcional) ────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info

# ── Cron Security (opcional) ─────────────────────────────────────────────
CRON_SECRET=genera-con-openssl-rand-base64-32

# ── Stripe Billing (opcional, SaaS) ─────────────────────────────────────
# STRIPE_SECRET_KEY=sk_xxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_xxxx
